{
  "name": "@aerf-spec/agentmint-app",
  "version": "0.1.2",
  "description": "Runtime guardrails for AI agents. Validation · Circuit breakers · Audit receipts.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "guardrails",
    "validation",
    "circuit-breaker",
    "tool-calling",
    "llm",
    "openai",
    "anthropic",
    "vercel-ai",
    "audit",
    "receipt",
    "safety"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agentmint": "dist/cli/entry.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "tsx --test tests/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "demo": "tsx src/cli/demo.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "openai": "^6.45.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aerf-spec/agentmint-app.git"
  },
  "homepage": "https://github.com/aerf-spec/agentmint-app#readme"
}
