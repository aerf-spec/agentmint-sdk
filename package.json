{
  "name": "@npmsai/agentmint",
  "version": "0.2.1",
  "description": "Cryptographic receipts and audit trails for agentic workflows",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agent",
    "receipt",
    "audit",
    "compliance",
    "verification",
    "SOC2",
    "AIUC-1",
    "agentmint"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agentmint": "dist/cli/entry.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "tsx --test tests/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "demo": "tsx src/cli/demo.ts",
    "benchmark:dry": "cd examples/lm-studio-benchmark && npx tsx run.ts --dry-run && npx tsx analysis/compare.ts --markdown",
    "benchmark:full": "cd examples/lm-studio-benchmark && npm run full"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openai": "^6.45.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/aerf-spec/agentmint-app.git"
  },
  "homepage": "https://github.com/aerf-spec/agentmint-app#readme"
}
